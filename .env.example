# Minecraft Server Configuration
# Copy this file to `.env` and fill in real values.

# Minecraft Version
VERSION=1.20.1

# Modloader (NEOFORGE, FORGE, FABRIC, or VANILLA)
TYPE=FORGE

# Forge Version (LATEST or specific version)
FORGE_VERSION=LATEST

# Server Memory Allocation
MEMORY=8G

# Server Properties
SERVER_NAME=thesonofmc
MOTD=your message of the day
DIFFICULTY=normal
GAMEMODE=survival
MAX_PLAYERS=6

# World Settings
LEVEL_NAME=world
SEED=

# Performance Settings
VIEW_DISTANCE=10
SIMULATION_DISTANCE=8

# RCON (internal only — used by the backup service for safe snapshots)
ENABLE_RCON=true
RCON_PASSWORD=CHANGE-ME
RCON_PORT=25575

# Backup Settings
BACKUP_INTERVAL=1h
BACKUP_PRUNE_DAYS=14
